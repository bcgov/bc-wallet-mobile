# SauceLabs environment variables (sauce runs only)
# Copy to .env.saucelabs and edit with your values:
#   cp .env.saucelabs.example .env.saucelabs
#
# Loaded automatically by wdio.shared.sauce.conf.ts for SauceLabs runs only.
# General e2e settings (variant, flow, device names, etc.) live in .env.e2e.

# --- SauceLabs credentials ---
SAUCE_USERNAME=your-username
SAUCE_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SAUCE_REGION=us

# --- SauceLabs app storage ---
ANDROID_APP_FILENAME=BCSC-Dev-latest.apk
IOS_APP_FILENAME=BCSC-Dev-latest.ipa

# --- iOS device targeting (optional) ---
# IOS_DEVICE_NAME=iPhone 15.*
# IOS_PLATFORM_VERSION=18

# --- Android device targeting (optional) ---
# ANDROID_DEVICE_NAME=Google Pixel 8.*
# ANDROID_PLATFORM_VERSION=15

# --- SauceLabs test metadata ---
BUILD_NAME=local-manual
TEST_NAME=E2E Tests (local)

# --- Migration tests (v3 → v4) ---
# V3 app filenames in Sauce Labs storage (initial app for migration tests).
# Same var names as the local migration configs; each config resolves them
# against its own source (local apps/ dir vs Sauce storage).
V3_ANDROID_APP=BCSC-v3.apk
V3_IOS_APP=BCSC-v3.ipa
