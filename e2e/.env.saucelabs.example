# SauceLabs credentials — cp .env.saucelabs.example .env.saucelabs (or cat this file > .env.saucelabs),
# then edit with your values. Before sauce tests: source e2e/.env.saucelabs

export SAUCE_USERNAME='your-username'
export SAUCE_ACCESS_KEY='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
export SAUCE_REGION='us'
export APP_FILENAME='BCSC-Dev-latest.aab'
export VARIANT='bcsc-dev'
export BUILD_NAME='local-manual'
export TEST_NAME='E2E Tests (local)'
export IOS_DEVICE='iPhone 16'
export IOS_VERSION='18.5'
export IOS_APP='BCWallet.app'
export ANDROID_DEVICE='Google.*'
export ANDROID_VERSION='13'
export ANDROID_APP='BCWallet.apk'