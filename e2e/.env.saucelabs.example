# E2E environment variables
# Copy to .env.saucelabs and edit with your values:
#   cp .env.saucelabs.example .env.saucelabs
#
# For SauceLabs runs, .env.saucelabs is loaded automatically by the config.
# No need to `source` — just run: yarn test:android:sauce or yarn test:ios:sauce

# --- SauceLabs (required for sauce runs) ---
SAUCE_USERNAME=your-username
SAUCE_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SAUCE_REGION=us

# --- App / build (SauceLabs) ---
# For Android use .aab, for iOS use .ipa
APP_FILENAME=BCSC-Dev-latest.aab
VARIANT=bcsc-dev
BUILD_NAME=local-manual
TEST_NAME=E2E Tests (local)

# --- iOS (local sim/device) ---
IOS_DEVICE=iPhone 16
IOS_VERSION=18.5
IOS_APP=BCWallet.app

# --- iOS real device only ---
# UDID=00008030-001234567890001E
# XCODE_ORG_ID=XXXXXXXXXX
# XCODE_SIGNING_ID=iPhone Developer

# --- Android (local emu/device) ---
# Use a version that matches your emulator (e.g. 15 for API 35). Leave unset to use config default (15.0).
ANDROID_DEVICE=Pixel_7
ANDROID_VERSION=15
ANDROID_APP=BCWallet.apk

# --- Android real device only ---
# UDID=emulator-5554

# --- Appium (optional) ---
# APPIUM_HOME=/custom/path/to/appium
