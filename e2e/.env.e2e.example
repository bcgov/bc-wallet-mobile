# E2E environment variables (general — all run targets)
# Copy to .env.e2e and edit with your values:
#   cp .env.e2e.example .env.e2e
#
# Loaded automatically by wdio.shared.conf.ts for every run target
# (local sim/emu, real device, and SauceLabs).

# --- Flow mode (simple|advanced) ---
E2E_FLOW=simple
VARIANT=bcsc # bcsc or bc-wallet

# --- iOS (local sim) ---
IOS_DEVICE=iPhone 16
IOS_VERSION=18.5
IOS_APP=BCSC.app # BCSC.app or BCWallet.app

# --- iOS real device only ---
# Device config uses IOS_APP_DEVICE (default BCWallet.ipa), not IOS_APP, so sim .app is not used on device
IOS_APP_DEVICE=BCSC.ipa # BCSC.ipa or BCWallet.ipa
IOS_UDID=XXXXXXXXXXXXXXXXXXXXXXXXXX
XCODE_ORG_ID=XXXXXXXXXX
# Quote the value (spaces). iPhone Developer / iPhone-Developer conflicts with WDA automatic signing on Xcode 15+.
XCODE_SIGNING_ID="Apple Development"
SHOW_XCODE_LOG=false

# --- Android (local emu/device) ---
# Use a version that matches your emulator (e.g. 15 for API 35). Leave unset to use config default (15.0).
ANDROID_DEVICE=Pixel_7
ANDROID_VERSION=15
ANDROID_APP=BCSC.apk # BCSC.apk or BCWallet.apk

# --- Android real device only ---
ANDROID_UDID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Appium (optional) ---
# APPIUM_HOME=/custom/path/to/appium
NO_RESET=false
