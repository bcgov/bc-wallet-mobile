# BCSC - QA
APP_NAME='BC Services Card'
APP_VERSION='4.1.0'
BUILD_TARGET='bcsc'
DEFAULT_ENVIRONMENT='QA'

# Android
ANDROID_PACKAGE_NAME='ca.bc.gov.id.servicescard.qa'
ANDROID_ICON_REF='ic_launcher'

# iOS
IOS_BUNDLE_ID='ca.bc.gov.idqa.servicescard'
IOS_PRODUCT_NAME='$(TARGET_NAME)'

# URL schemes (comma-separated) — replaces base bcwallet/didcomm schemes
IOS_URL_SCHEMES='ca.bc.gov.idqa.servicescard,ca.bc.gov.idqa.servicescard.v2'
ANDROID_URL_SCHEMES='ca.bc.gov.id.servicescard.qa,ca.bc.gov.idqa.servicescard.v2'

# Base variant to inherit shared assets from
BASE_VARIANT='_bcsc-base'

# iOS signing / distribution
IOS_EXPORT_METHOD='app-store'
IOS_PROVISIONING_PROFILE_SECRET='BUILD_PROVISION_PROFILE_SAQA_BASE64'
IOS_GOOGLE_SERVICES_SECRET='GOOGLE_SERVICES_CREDENTIALS_IOS_SAQA_BASE64'

# Android signing / distribution
ANDROID_JKS_BASE64_SECRET='PLAY_STORE_JKS_BASE64_SAQA'
ANDROID_JKS_ALIAS_SECRET='PLAY_STORE_JKS_ALIAS_SAQA'
ANDROID_JKS_PASSWD_SECRET='PLAY_STORE_JKS_PASSWD_SAQA'
ANDROID_GOOGLE_SERVICES_SECRET='GOOGLE_SERVICES_CREDENTIALS_ANDROID_SAQA_BASE64'

# SauceLabs
SAUCE_LABS_PREFIX='BCSC-QA'

# TestFlight beta groups (newline-separated)
TESTFLIGHT_BETA_GROUPS='IDIM Testers for QA'
