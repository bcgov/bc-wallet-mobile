# BC Wallet - Production (Default)
# This is the project default configuration. No changes are needed.
# The apply-variant script exits as a no-op for this variant.

APP_NAME='BC Wallet'
APP_VERSION='1.0.27'
BUILD_TARGET='bcwallet'
DEFAULT_ENVIRONMENT='PROD'

# Android
ANDROID_PACKAGE_NAME='ca.bc.gov.BCWallet'
ANDROID_ICON_REF='ic_launcher'

# iOS
IOS_BUNDLE_ID='ca.bc.gov.BCWallet'
IOS_PRODUCT_NAME='BCWallet'

# iOS signing / distribution
IOS_EXPORT_METHOD='app-store'
IOS_PROVISIONING_PROFILE_SECRET='BUILD_PROVISION_PROFILE_BASE64'
IOS_GOOGLE_SERVICES_SECRET='GOOGLE_SERVICES_CREDENTIALS_IOS_BASE64'

# Android signing / distribution
ANDROID_JKS_BASE64_SECRET='PLAY_STORE_JKS_BASE64'
ANDROID_JKS_ALIAS_SECRET='PLAY_STORE_JKS_ALIAS'
ANDROID_JKS_PASSWD_SECRET='PLAY_STORE_JKS_PASSWD'
ANDROID_GOOGLE_SERVICES_SECRET='GOOGLE_SERVICES_CREDENTIALS_ANDROID_BASE64'

# SauceLabs
SAUCE_LABS_PREFIX='BCWallet'

# TestFlight beta groups (newline-separated)
TESTFLIGHT_BETA_GROUPS='The Team
IDIM Team'
