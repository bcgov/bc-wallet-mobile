# BCSC - Production
APP_NAME='BC Services Card'
APP_VERSION='4.0.0'
BUILD_TARGET='bcsc'

# Android
ANDROID_PACKAGE_NAME='ca.bc.gov.id.servicescard'
ANDROID_ICON_REF='ic_launcher_mono'

# iOS
IOS_BUNDLE_ID='ca.bc.gov.id.servicescard'
IOS_PRODUCT_NAME='$(TARGET_NAME)'
IOS_PBXPROJ_TARGET_NAME='BCWallet'

# URL schemes (comma-separated) — replaces base bcwallet/didcomm schemes
IOS_URL_SCHEMES='ca.bc.gov.id.servicescard,ca.bc.gov.id.servicescard.v2'
ANDROID_URL_SCHEMES='ca.bc.gov.id.servicescard,ca.bc.gov.id.servicescard.v2'

# Base variant to inherit shared assets from
BASE_VARIANT='_bcsc-base'

# iOS signing / distribution
IOS_EXPORT_METHOD='app-store'
IOS_PROVISIONING_PROFILE_UUID='REPLACE_WITH_BCSC_PROD_PROV_PROFILE_UUID'
IOS_PROVISIONING_PROFILE_SECRET='BUILD_PROVISION_PROFILE_SA_BASE64'
IOS_GOOGLE_SERVICES_SECRET='GOOGLE_SERVICES_CREDENTIALS_IOS_SA_BASE64'

# Android signing / distribution
ANDROID_JKS_BASE64_SECRET='PLAY_STORE_JKS_BASE64_SA'
ANDROID_JKS_ALIAS_SECRET='PLAY_STORE_JKS_ALIAS_SA'
ANDROID_JKS_PASSWD_SECRET='PLAY_STORE_JKS_PASSWD_SA'
ANDROID_GOOGLE_SERVICES_SECRET='GOOGLE_SERVICES_CREDENTIALS_ANDROID_SA_BASE64'

# SauceLabs
SAUCE_LABS_PREFIX='BCSC-Prod'

# TestFlight beta groups (newline-separated)
TESTFLIGHT_BETA_GROUPS='IDIM testers for PROD env'
